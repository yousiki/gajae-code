{
	"type": "module",
	"private": true,
	"name": "@gajae-code/orchestration-token-benchmark",
	"version": "0.0.1",
	"description": "Deterministic internal benchmark for orchestration token efficiency (token metrics, prompt-prefix stability, spawn-gate decisions). No live-model calls.",
	"author": "Yeachan-Heo",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yousiki/gajae-code.git",
		"directory": "packages/orchestration-token-benchmark"
	},
	"main": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"start": "bun run src/index.ts",
		"bench:live": "bun run src/live-runner.ts"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"homepage": "https://gajae-code.com"
}
