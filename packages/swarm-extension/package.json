{
	"type": "module",
	"name": "@gajae-code/swarm-extension",
	"version": "0.1.2",
	"description": "Swarm orchestration extension for gjc",
	"homepage": "https://gajae-code.dev",
	"author": "Derek Rynd",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gajae-ai/gajae-code.git",
		"directory": "packages/swarm-extension"
	},
	"bugs": {
		"url": "https://github.com/gajae-ai/gajae-code/issues"
	},
	"keywords": [
		"swarm",
		"orchestration",
		"agent",
		"extension"
	],
	"bin": {
		"gjc-swarm": "src/cli.ts"
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@gajae-code/utils": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14"
	},
	"peerDependencies": {
		"@gajae-code/coding-agent": "workspace:*"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"gjc": {
		"extensions": [
			"./src/extension.ts"
		]
	},
	"files": [
		"src",
		"README.md"
	]
}
