{
	"type": "module",
	"private": true,
	"name": "@gajae-code/telegram-remote",
	"version": "0.0.1",
	"description": "v0 Telegram operator remote for Gajae-Code sessions: a tiny, safe command + bounded-read gateway over the Coordinator MCP. Lifecycle and observation only; not a remote cockpit.",
	"author": "Yeachan-Heo",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gajae-ai/gajae-code.git",
		"directory": "packages/telegram-remote"
	},
	"main": "./src/index.ts",
	"bin": {
		"gjc-telegram-remote": "./src/cli.ts"
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"start": "bun run src/cli.ts"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"homepage": "https://gaebal-gajae.dev",
	"dependencies": {
		"@gajae-code/coding-agent": "catalog:"
	}
}
