{
	"type": "module",
	"name": "@gajae-code/bridge-client",
	"version": "0.7.2",
	"description": "TypeScript client SDK for the GJC backend bridge protocol",
	"homepage": "https://gaebal-gajae.dev",
	"author": "Yeachan-Heo",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gajae-ai/gajae-code.git",
		"directory": "packages/bridge-client"
	},
	"bugs": {
		"url": "https://github.com/gajae-ai/gajae-code/issues"
	},
	"keywords": [
		"gjc",
		"bridge",
		"sdk"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
}
