{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": [
			"ES2024",
			"DOM",
			"DOM.Iterable"
		],
		"jsx": "react-jsx",
		"types": [
			"vite/client",
			"bun"
		],
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"allowImportingTsExtensions": true,
		"target": "ESNext"
	},
	"include": [
		"src",
		"vite.config.ts"
	]
}
