        },
        "turns": {
          "type": [
            "array",
            "null"
          ],
          "items": true
        }
      },
      "definitions": {
        "ThreadStatus": {
          "description": "Lifecycle status of a thread in the registry.",
          "type": "string",
          "enum": [
            "idle",
            "running",
            "archived",
            "deleted"
          ]
