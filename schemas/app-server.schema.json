{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "gjc-app-server wire protocol",
  "description": "Rust-derived JSON Schema for the codex-compatible app-server wire surface.",
  "definitions": {
    "Request": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Request",
      "description": "An inbound request: `{ \"id\", \"method\", \"params\"? }`.",
      "type": "object",
      "required": [
        "id",
        "method"
      ],
      "properties": {
        "id": {
          "$ref": "#/definitions/RequestId"
        },
        "method": {
          "type": "string"
        },
        "params": true
      },
      "definitions": {
        "RequestId": {
          "description": "Opaque JSON-RPC request id (string or number), preserved verbatim so responses echo the exact client id.",
          "anyOf": [
            {
              "type": "integer",
              "format": "int64"
            },
            {
              "type": "string"
            }
          ]
        }
      }
    },
    "Response": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Response",
      "description": "An outbound response: exactly one of `result`/`error` is present.",
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/AppServerError"
            },
            {
              "type": "null"
            }
          ]
        },
        "id": {
          "$ref": "#/definitions/RequestId"
        },
        "result": true
      },
      "definitions": {
        "AppServerError": {
          "description": "A structured error that maps directly onto a JSON-RPC error object.",
          "type": "object",
          "required": [
            "code",
            "message"
          ],
          "properties": {
            "code": {
              "type": "integer",
              "format": "int32"
            },
            "data": true,
            "message": {
              "type": "string"
            }
          }
        },
        "RequestId": {
          "description": "Opaque JSON-RPC request id (string or number), preserved verbatim so responses echo the exact client id.",
          "anyOf": [
            {
              "type": "integer",
              "format": "int64"
            },
            {
              "type": "string"
            }
          ]
        }
      }
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "description": "An outbound server notification (no id).",
      "type": "object",
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string"
        },
        "params": true
      }
    },
    "ClientNotification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ClientNotification",
      "description": "An inbound client notification (no id): `{ \"method\", \"params\"? }`.",
      "type": "object",
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string"
        },
        "params": true
      }
    },
    "RequestId": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RequestId",
      "description": "Opaque JSON-RPC request id (string or number), preserved verbatim so responses echo the exact client id.",
      "anyOf": [
        {
          "type": "integer",
          "format": "int64"
        },
        {
          "type": "string"
        }
      ]
    },
    "AppServerError": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppServerError",
      "description": "A structured error that maps directly onto a JSON-RPC error object.",
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "data": true,
        "message": {
          "type": "string"
        }
      }
    },
    "ThreadIdentity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ThreadIdentity",
      "description": "Immutable identity + mutable metadata + current backend generation.",
      "type": "object",
      "required": [
        "generation",
        "metadata",
        "status",
        "thread_id"
      ],
      "properties": {
        "generation": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "metadata": {
          "$ref": "#/definitions/SessionMetadata"
        },
        "status": {
          "$ref": "#/definitions/ThreadStatus"
        },
        "thread_id": {
          "type": "string"
        }
      },
      "definitions": {
        "SessionMetadata": {
          "description": "Mutable TS-side session metadata attached to an immutable thread identity.",
          "type": "object",
          "properties": {
            "cwd": {
              "type": [
                "string",
                "null"
              ]
            },
            "forkedFromId": {
              "type": [
                "string",
                "null"
              ]
            },
            "model": true,
            "modelConfig": true,
            "sessionDir": {
              "type": [
                "string",
                "null"
              ]
            },
            "sessionFile": {
              "type": [
                "string",
                "null"
              ]
            },
            "sessionId": {
              "type": [
                "string",
                "null"
              ]
            },
            "systemPromptAppend": {
              "type": [
                "string",
                "null"
              ]
            },
            "thinking": true,
            "todos": true
          }
        },
        "ThreadStatus": {
          "description": "Lifecycle status of a thread in the registry.",
          "type": "string",
          "enum": [
            "idle",
            "running",
            "archived",
            "deleted"
          ]
        }
      }
    },
    "ThreadStatus": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ThreadStatus",
      "description": "Lifecycle status of a thread in the registry.",
      "type": "string",
      "enum": [
        "idle",
        "running",
        "archived",
        "deleted"
      ]
    },
    "SessionMetadata": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SessionMetadata",
      "description": "Mutable TS-side session metadata attached to an immutable thread identity.",
      "type": "object",
      "properties": {
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "forkedFromId": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": true,
        "modelConfig": true,
        "sessionDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "sessionFile": {
          "type": [
            "string",
            "null"
          ]
        },
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "systemPromptAppend": {
          "type": [
            "string",
            "null"
          ]
        },
        "thinking": true,
        "todos": true
      }
    },
    "ItemState": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ItemState",
      "description": "Item lifecycle states.",
      "type": "string",
      "enum": [
        "new",
        "started",
        "streaming",
        "completing",
        "completed",
        "failed",
        "interrupted"
      ]
    },
    "TurnState": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TurnState",
      "description": "Turn lifecycle states.",
      "type": "string",
      "enum": [
        "idle",
        "accepted",
        "started",
        "completing",
        "completed",
        "failed",
        "interrupted"
      ]
    },
    "TerminalCause": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TerminalCause",
      "description": "Terminal cause for a turn. Priority: `Failed` > `Interrupted` > `Completed`.",
      "type": "string",
      "enum": [
        "completed",
        "interrupted",
        "failed"
      ]
    },
    "EmptyResult": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "EmptyResult",
      "description": "Empty object result used by `gjc/todos/set`, `gjc/hostTools/*`, `thread/delete`, and `thread/archive`; see `server.rs` handlers returning `json!({})`.",
      "type": "object"
    },
    "InitializeParams": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "InitializeParams",
      "description": "`initialize` params are currently ignored/lenient; see `server.rs::handle_initialize`.",
      "type": "object"
    },
    "InitializeResult": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "InitializeResult",
      "description": "`initialize` result emitted by `server.rs::handle_initialize`.",
      "type": "object",
      "required": [
        "platformFamily",
        "platformOs",
        "userAgent"
      ],
      "properties": {
        "platformFamily": {
          "type": "string"
        },
        "platformOs": {
          "type": "string"
        },
        "userAgent": {
          "type": "string"
        }
      }
    },
    "InitializedParams": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "InitializedParams",
      "description": "Client `initialized` notification params; `server.rs::dispatch` only checks the method.",
      "type": "object"
    },
    "ThreadStartParams": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AnyValue"
    },
    "ThreadResumeParams": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ThreadResumeParams",
      "description": "`thread/resume` params require `threadId` and otherwise pass through to the backend; see `server.rs::handle_thread_resume`.",
      "type": "object",
      "required": [
        "threadId"
      ],
      "properties": {
        "threadId": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "ThreadForkParams": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AnyValue"
    },
    "ThreadIdParams": {
      "$schema": "http://json-schema.org/draft-07/schema#",
