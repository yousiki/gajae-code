[
  {
    "name": "classify_issue",
    "description": "First triage step. Classify the issue, apply labels on GitHub, pick the workflow branch (bug → repro+fix+PR, question → reply only, etc.). MUST be called before any other `gh_*` action on a new issue.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "primary": {
          "type": "string",
          "enum": [
            "bug",
            "enhancement",
            "question",
            "proposal",
            "documentation",
            "invalid",
            "duplicate"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "prio:p0",
            "prio:p1",
            "prio:p2",
            "prio:p3"
          ]
        },
        "functional": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "agent",
              "tool",
              "tui",
              "cli",
              "prompting",
              "sdk",
              "auth",
              "setup",
              "ux",
              "providers"
            ]
          }
        },
        "provider": {
          "type": "string"
        },
        "platform": {
          "type": "string",
          "enum": [
            "platform:linux",
            "platform:macos",
            "platform:windows",
            "platform:wsl"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "branch_slug": {
          "type": "string"
        }
      },
      "required": [
        "primary",
        "rationale"
      ],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "set_issue_labels",
    "description": "Append labels to the originating issue/PR. NEVER removes existing labels.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "number": {
          "type": "integer"
        }
      },
      "required": [
        "labels"
      ],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "gh_post_comment",
    "description": "Post a comment on the inbound thread (PR for PR conversations/reviews, originating issue otherwise). Pass `number` ONLY to post elsewhere.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "body": {
          "type": "string"
        },
        "number": {
          "type": "integer"
        }
      },
      "required": [
        "body"
      ],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "gh_push_branch",
    "description": "Push the workspace branch to origin. Pre-publish gate (when the repo defines them): `bun run fix` → auto-commit any formatter diff as `style: bun run fix` → `bun check`. On `bun check` failure, fix the cause and retry. Pre-existing breakage on `main` against the same paths NOT caused by your diff → retry with `skip_checks=true` and document the bypass in the follow-up comment. Dirty-tree gate runs unconditionally.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "branch": {
          "type": "string"
        },
        "skip_checks": {
          "type": "boolean"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "gh_open_pr",
    "description": "Open a PR from the workspace branch using the four-section body template. Same pre-publish gate as `gh_push_branch`: `bun run fix` → auto-commit formatter diff as `style: bun run fix` → `bun check`. On failure, fix and retry. Pre-existing `main` breakage NOT caused by your diff → `skip_checks=true` and document the bypass in the PR's `## Verification` section.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "base": {
          "type": "string"
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "skip_checks": {
          "type": "boolean"
        }
      },
      "required": [
        "title",
        "body"
      ],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "gh_request_review",
    "description": "Request reviewers and/or add assignees on the open PR.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "reviewers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assignees": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "repro_record",
    "description": "Persist a reproduction transcript (command, output, exit code) for the issue.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "exit_code": {
          "type": "integer"
        },
        "reproduced": {
          "type": "boolean"
        }
      },
      "required": [
        "title",
        "command",
        "output",
        "exit_code"
      ],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "mark_unable_to_reproduce",
    "description": "Close the loop without a PR: comment with diagnosis + info request, mark issue abandoned.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "diagnosis": {
          "type": "string"
        },
        "info_needed": {
          "type": "string"
        }
      },
      "required": [
        "diagnosis",
        "info_needed"
      ],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "abort_task",
    "description": "Irrecoverably abandon this task WITHOUT posting any visible message. Use ONLY for orchestrator/environment defects you cannot work around (broken filesystem permissions, missing system tools, corrupted git metadata, harness bugs). NEVER for normal workflow problems — failed builds, missing repro info, unclear requests use `gh_post_comment` or `mark_unable_to_reproduce` instead. `reason` is audit-only and NEVER shown to the reporter.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "reason"
      ],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  },
  {
    "name": "fetch_issue_thread",
    "description": "Refetch the originating issue and its comments. Use sparingly.",
    "inputSchema": {
      "type": "object",
      "properties": {},
      "required": [],
      "additionalProperties": false
    },
    "resultPolicy": {
      "type": "text",
      "redactCredentials": true
    },
    "redactionHints": {
      "credentials": true
    }
  }
]
